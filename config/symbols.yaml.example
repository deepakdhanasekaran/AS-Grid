# 多币种网格交易配置文件示例
# 每个币种可以独立设置网格间距、初始数量和杠杆倍数
# 
# 配置说明：
# - name: 币种名称（如SUI、SOL、BTC等）
# - grid_spacing: 网格间距，决定每个网格之间的价格差
# - initial_quantity: 初始交易数量
# - leverage: 杠杆倍数（1-125倍）
# - contract_type: 合约类型（USDC或USDT）
# - position_threshold_factor: 锁仓阈值系数
# - position_limit_factor: 持仓阈值系数

symbols:
    
  # SOL币种配置  
  - name: SOL
    grid_spacing: 0.005       # 网格间距0.005
    initial_quantity: 0.05    # 初始数量0.05个
    leverage: 20              # 20倍杠杆
    contract_type: USDC       # USDC合约
    position_threshold_factor: 20
    position_limit_factor: 10
    
  # BTC币种配置示例
  - name: BTC
    grid_spacing: 50          # 网格间距50美元
    initial_quantity: 0.001   # 初始数量0.001个
    leverage: 10              # 10倍杠杆
    contract_type: USDT       # USDT合约
    position_threshold_factor: 20
    position_limit_factor: 10
    maker_fee_rate: 0.0002
    taker_fee_rate: 0.0005
    funding_buffer_rate: 0.0003
    min_net_edge_rate: 0.0005
    max_spread_rate: 0.0015
    range_filter_lookback: 20
    range_min_samples: 8
    range_min_pct: 0.0010
    range_breakout_pct: 0.0150
    range_pause_seconds: 45
    
  # ETH币种配置示例
  - name: ETH
    grid_spacing: 5           # 网格间距5美元
    initial_quantity: 0.01    # 初始数量0.01个
    leverage: 15              # 15倍杠杆
    contract_type: USDT       # USDT合约
    position_threshold_factor: 20
    position_limit_factor: 10
    maker_fee_rate: 0.0002
    taker_fee_rate: 0.0005
    funding_buffer_rate: 0.0003
    min_net_edge_rate: 0.0005
    max_spread_rate: 0.0015
    range_filter_lookback: 20
    range_min_samples: 8
    range_min_pct: 0.0010
    range_breakout_pct: 0.0150
    range_pause_seconds: 45
    
  # DOGE币种配置示例
  - name: DOGE
    grid_spacing: 0.0001      # 网格间距0.0001
    initial_quantity: 100     # 初始数量100个
    leverage: 30              # 30倍杠杆
    contract_type: USDC       # USDC合约
    position_threshold_factor: 20
    position_limit_factor: 10
    maker_fee_rate: 0.0002
    taker_fee_rate: 0.0005
    funding_buffer_rate: 0.0003
    min_net_edge_rate: 0.0005
    max_spread_rate: 0.0015
    range_filter_lookback: 20
    range_min_samples: 8
    range_min_pct: 0.0010
    range_breakout_pct: 0.0150
    range_pause_seconds: 45

# 可选：侧向市场筛选器
scanner:
  enabled: false              # true 时先扫描再启动最适合横盘的币种
  timeframe: 15m
  lookback: 96
  top_n: 3
  min_score: 0.55
  min_range_pct: 0.0020
  ideal_range_pct: 0.0120
  max_range_pct: 0.0500
  max_direction_pct: 0.0060
  max_spread_pct: 0.0015
  min_quote_volume: 0
  max_funding_abs: 0.0005
