# 交易所配置
EXCHANGE=gate  # 交易所选择: gate 或 binance
CONTRACT_TYPE=USDT  # 合约类型: USDT 或 USDC (仅币安需要)

# Gate.io API 配置

# Gate.io API 配置
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Binance API 配置 (当 EXCHANGE=binance 时使用)
# API_KEY=your_binance_api_key_here
# API_SECRET=your_binance_api_secret_here
# BINANCE_DEMO_TRADING=true  # 使用 Binance Futures Demo Trading 账号时开启
# BINANCE_SANDBOX=true       # 兼容旧配置；多币种期货会自动走 Demo Trading

# 交易配置
COIN_NAME=X
GRID_SPACING=0.004
INITIAL_QUANTITY=1
LEVERAGE=20
MAKER_FEE_RATE=0.0002
TAKER_FEE_RATE=0.0005
FUNDING_BUFFER_RATE=0.0003
MIN_NET_EDGE_RATE=0.0005
MAX_SPREAD_RATE=0.0015
RANGE_FILTER_LOOKBACK=20
RANGE_MIN_SAMPLES=8
RANGE_MIN_PCT=0.0010
RANGE_BREAKOUT_PCT=0.0150
RANGE_PAUSE_SECONDS=45

# 侧向市场筛选器（可选）
SIDEWAYS_SCAN_ENABLED=true
SIDEWAYS_SCAN_TIMEFRAME=15m
SIDEWAYS_SCAN_LOOKBACK=96
SIDEWAYS_SCAN_TOP_N=2
SIDEWAYS_SCAN_MIN_SCORE=0.60
SIDEWAYS_SCAN_MIN_RANGE_PCT=0.0020
SIDEWAYS_SCAN_IDEAL_RANGE_PCT=0.0120
SIDEWAYS_SCAN_MAX_RANGE_PCT=0.0500
SIDEWAYS_SCAN_MAX_DIRECTION_PCT=0.0060
SIDEWAYS_SCAN_MAX_SPREAD_PCT=0.0015
SIDEWAYS_SCAN_MIN_QUOTE_VOLUME=0
SIDEWAYS_SCAN_MAX_FUNDING_ABS=0.0005

# Telegram 通知配置 (可选)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ENABLE_NOTIFICATIONS=true
NOTIFICATION_INTERVAL=3600
